    "i18next": "^25.10.5",
    "i18next-http-backend": "^3.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^16.6.2",
    "react-router": "^7.13.2",
    "web-vitals": "^5.1.0",
    "zod": "^4.3.6"
